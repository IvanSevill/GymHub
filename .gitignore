# ──────────────────────────────────────────
#  GymHub – .gitignore
# ──────────────────────────────────────────

# ── OS / Editor ───────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.suo
*.user

# ── Environment & Secrets ─────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ══════════════════════════════════════════
#  BACKEND  (Python / FastAPI)
# ══════════════════════════════════════════

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
site/

# Database files
*.db
*.sqlite
*.sqlite3

# Google OAuth tokens / credentials
token.json
credentials.json
google_token.pickle

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# Logs
*.log

# ══════════════════════════════════════════
#  FRONTEND-REACT  (Vite + React)
# ══════════════════════════════════════════

frontend-react/node_modules/
frontend-react/dist/
frontend-react/.vite/
frontend-react/vite_log.txt

# ══════════════════════════════════════════
#  FRONTEND-ANDROID  (Android / Gradle)
# ══════════════════════════════════════════

# Build output
frontend-android/.gradle/
frontend-android/build/
frontend-android/*/build/
frontend-android/local.properties

# IntelliJ / Android Studio
frontend-android/.idea/
frontend-android/*.iml
frontend-android/*.ipr
frontend-android/*.iws
frontend-android/.navigation/
frontend-android/captures/

# Keystore files
*.jks
*.keystore

# Generated / signed APKs – keep out of VCS
*.apk
*.aab

# Java heap dumps & profiling snapshots
*.hprof

# Kotlin incremental caches
frontend-android/.kotlin/

# Android Studio / IntelliJ profiling & temp files
frontend-android/captures/
frontend-android/.navigation/
frontend-android/lint.xml
frontend-android/proguard-rules.pro
