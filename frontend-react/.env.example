# ─── GymHub Frontend — build-time environment variables (Vite) ────────────────
# These are embedded into the bundle at build time, not read at runtime.

# Public URL of the backend API
VITE_API_URL=http://localhost:8000

# Public URL of the AI server (chat / SSE)
VITE_AI_URL=http://localhost:8001

# Google OAuth client ID used by the login flow
VITE_GOOGLE_CLIENT_ID=your-google-client-id
