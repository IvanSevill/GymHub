# GymHub MCP Server — local development
# Only needed if you run gymhub-mcp standalone (e.g. with Claude Desktop).
# When used through ai-server, these are injected automatically — no .env needed.

# Same database as the backend
DATABASE_URL=sqlite:///./gymhub.db

# Your user ID from the GymHub database
# → SELECT id FROM users WHERE email='you@example.com';
GYMHUB_USER_ID=your-user-uuid-here

# A valid GymHub JWT (needed for write tools — create_workout, sync_pending_cardio, etc.)
# → Log in at http://localhost:5173, then: localStorage.getItem('token')
GYMHUB_TOKEN=your-jwt-token-here

BACKEND_URL=http://localhost:8000
