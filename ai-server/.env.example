# Environment variables for GymHub AI Server

# URL of the main backend; the AI server reads/writes all data through its REST API
BACKEND_URL="http://localhost:8000"

# Public URL of this AI server (defaults to http://localhost:$PORT)
AI_SERVER_URL="http://localhost:8001"

# Frontend URL for CORS configuration
FRONTEND_URL="http://localhost:5173"

# Must match the backend SECRET_KEY to validate the same JWT access tokens
SECRET_KEY="your-super-secret-key-replace-with-a-strong-random-one"

# Google Gemini API key for text generation
GEMINI_API_KEY="your-gemini-api-key"

# Gemini model identifier (deployment uses gemini-2.5-flash; code falls back to gemini-2.0-flash if unset)
GEMINI_MODEL="gemini-2.5-flash"

# Path to the MCP server script launched as a child process
# (defaults to ../gymhub-mcp/server.py relative to the AI server)
MCP_SERVER_PATH=
