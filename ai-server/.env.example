# ─── GymHub AI Server — environment variables ─────────────────────────────────
# The AI server has NO database access: all data goes through the backend's REST API.

# ─── Required ────────────────────────────────────────────────────────────────
# Google Gemini API key for text generation
GEMINI_API_KEY=your-gemini-api-key

# Must match the backend SECRET_KEY to validate the same JWT access tokens
SECRET_KEY=replace-with-a-strong-random-secret

# ─── Service URLs ────────────────────────────────────────────────────────────
# Main backend; the AI server reads/writes all data through its REST API
BACKEND_URL=http://localhost:8000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ─── Optional ────────────────────────────────────────────────────────────────
# Gemini model (code falls back to gemini-2.0-flash; deployment uses gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
