# Environment variables for GymHub Backend v2

# Supabase PostgreSQL connection (Settings > Database > Connection string > Session mode)
# In local development, defaults to sqlite:///./gymhub.db if omitted.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Deployment environment: "production" enables strict CORS and Secure cookies
ENVIRONMENT="development"

# Public URL of this backend (used to build OAuth callback URLs)
BACKEND_HOST="http://localhost:8000"

# Frontend URL for CORS configuration and OAuth redirects
FRONTEND_URL="http://localhost:5173"

# Secret key for signing/verifying the JWT access token
SECRET_KEY="your-super-secret-key-replace-with-a-strong-random-one"

# Separate secret for signing the refresh token (optional — falls back to SECRET_KEY)
REFRESH_SECRET_KEY=

# Google OAuth Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Fitbit OAuth Credentials
FITBIT_CLIENT_ID="your-fitbit-client-id"
FITBIT_CLIENT_SECRET="your-fitbit-client-secret"
# OAuth callback (defaults to {BACKEND_HOST}/auth/fitbit/callback if omitted)
FITBIT_REDIRECT_URI=

# List of root user emails (comma-separated) for admin privileges
ROOT_EMAILS="admin@example.com,another_admin@example.com"

# Exercise media APIs (optional — exercise library feature)
YOUTUBE_API_KEY=
PEXELS_API_KEY=
