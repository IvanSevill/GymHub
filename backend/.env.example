# ─── GymHub Backend — environment variables ───────────────────────────────────

# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL (Supabase) connection. Omit in local dev to fall back to sqlite:///./gymhub.db
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Secret for signing/verifying the JWT access token (must match the AI server)
SECRET_KEY=replace-with-a-strong-random-secret

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Fitbit OAuth credentials
FITBIT_CLIENT_ID=your-fitbit-client-id
FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# Emails (comma-separated) granted the admin role (is_root)
ROOT_EMAILS=you@example.com

# ─── Service URLs ────────────────────────────────────────────────────────────
# "production" enables strict CORS and Secure cookies; use "development" locally
ENVIRONMENT=development

# Public URL of this backend (used to build OAuth callback URLs)
BACKEND_HOST=http://localhost:8000

# Frontend URL for CORS and OAuth redirects
FRONTEND_URL=http://localhost:5173

# Fitbit OAuth callback (defaults to {BACKEND_HOST}/auth/fitbit/callback if omitted)
FITBIT_REDIRECT_URI=http://localhost:8000/auth/fitbit/callback

# ─── Optional ────────────────────────────────────────────────────────────────
# Exercise media APIs (exercise library enrichment — optional)
YOUTUBE_API_KEY=
PEXELS_API_KEY=

# GymChat rate limit (non-root users). Defaults: 5 messages per 120-minute
# fixed window anchored at the first message. Lower to test the limit/countdown
# without waiting, e.g. CHAT_RATE_LIMIT_COUNT=2 and CHAT_RATE_LIMIT_MINUTES=3.
CHAT_RATE_LIMIT_COUNT=5
CHAT_RATE_LIMIT_MINUTES=120
CHAT_HISTORY_LIMIT=10
