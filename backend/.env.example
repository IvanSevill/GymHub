# Environment variables for GymHub Backend v2

# Database Configuration
# For PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/dbname"
# For SQLite (development/testing):
# DATABASE_URL="sqlite:///./test.db"

# Frontend URL for CORS configuration
FRONTEND_URL="http://localhost:5173"

# Secret key for JWT token encryption
SECRET_KEY="your-super-secret-key-replace-with-a-strong-random-one"

# Google OAuth Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Fitbit OAuth Credentials
FITBIT_CLIENT_ID="your-fitbit-client-id"
FITBIT_CLIENT_SECRET="your-fitbit-client-secret"

# List of root user emails (comma-separated) for admin privileges
ROOT_EMAILS="admin@example.com,another_admin@example.com"
